const axios = require('axios');

const VTPASS_BASE = process.env.VTPASS_BASE || 'https://sandbox.vtpass.com/api';
const VTPASS_USERNAME = process.env.VTPASS_USERNAME;
const VTPASS_PASSWORD = process.env.VTPASS_PASSWORD;

const vtpassAxios = axios.create({
  baseURL: VTPASS_BASE,
  headers: {
    'api-key': VTPASS_USERNAME,
    'secret-key': VTPASS_PASSWORD,
    'Content-Type': 'application/json',
    'cache-control': 'no-cache'
  }
});

module.exports = vtpassAxios;
